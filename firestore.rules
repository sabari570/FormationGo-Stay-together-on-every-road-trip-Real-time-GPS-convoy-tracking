rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isJourneyMember(journeyId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/journeys/$(journeyId)/member_auth/$(request.auth.uid));
    }

    match /journeys/{journeyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;

      match /members/{memberId} {
        allow read, write: if request.auth != null;
      }
      match /member_auth/{authUid} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == authUid;
        allow delete: if false;
      }
      match /locations/{memberId} {
        allow read, write: if request.auth != null;
      }
      match /checkpoints/{cpId} {
        allow read, write: if request.auth != null;
      }
      match /route_pois/{poiId} {
        allow read, write: if request.auth != null;
      }
      match /chat_messages/{msgId} {
        allow read, write: if request.auth != null;
      }
      match /group_messages/{msgId} {
        allow read, create: if isJourneyMember(journeyId);
        allow update, delete: if false;
      }
    }
  }
}
